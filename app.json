{
  "expo": {
    "name": "ChatLux",
    "slug": "ChatLux",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "chatlux",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0f1e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ali12.mo4.ChatLux"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0a0f1e"
      },
      "package": "com.ali12.mo4.ChatLux",
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4895f1ef-4406-4397-9033-fe5f2d731b18"
      }
    }
  }
}
